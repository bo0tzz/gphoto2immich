# Maintainer: bo0tzz <boet@futo.org>
pkgname=gphoto2immich-git
_pkgname=gphoto2immich
pkgver=r0
pkgrel=1
pkgdesc="Auto-sync daemon for Fujifilm (and other libgphoto2) cameras into Immich"
arch=('x86_64')
url="https://github.com/bo0tzz/gphoto2immich"
license=('AGPL-3.0-or-later')
depends=('libgphoto2' 'libxml2' 'gcc-libs')
makedepends=('git' 'rust' 'cargo')
provides=("$_pkgname")
conflicts=("$_pkgname")
source=("$_pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
    cd "$_pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$_pkgname"
    cargo fetch --locked
}

build() {
    cd "$_pkgname"
    export CARGO_TARGET_DIR=target
    # Arch's default CFLAGS include `-fno-plt`, which inlines PLT calls
    # at the call site. ring's hand-written assembly assumes traditional
    # PLT semantics, so its `ring_core_*` symbols end up unresolved at
    # link time under makepkg. Strip the flag for our build only.
    export CFLAGS="${CFLAGS//-fno-plt/}"
    export CXXFLAGS="${CXXFLAGS//-fno-plt/}"
    cargo build --release --frozen
}

check() {
    cd "$_pkgname"
    cargo test --release --frozen --no-run >/dev/null
}

package() {
    cd "$_pkgname"
    install -Dm755 "target/release/$_pkgname" "$pkgdir/usr/bin/$_pkgname"
    install -Dm644 packaging/systemd/gphoto2immich.service \
        "$pkgdir/usr/lib/systemd/user/gphoto2immich.service"
    install -Dm644 packaging/systemd/env.example \
        "$pkgdir/usr/share/doc/$_pkgname/env.example"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$_pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
}
