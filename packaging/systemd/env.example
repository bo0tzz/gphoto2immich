# Copy to ~/.config/fujimmich/env and chmod 600.
# Loaded by the systemd user unit at packaging/systemd/fujimmich.service.

IMMICH_URL=https://immich.example.com/
IMMICH_API_KEY=replace-me

# IANA timezone the camera's clock is set to. Required.
FUJI_TZ=Europe/Amsterdam

# Optional: defaults shown.
STACK_JPEG_RAF=true
LOG_LEVEL=info
