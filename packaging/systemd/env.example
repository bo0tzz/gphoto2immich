# Copy to ~/.config/gphoto2immich/env and chmod 600.
# Loaded by the systemd user unit at packaging/systemd/gphoto2immich.service.

IMMICH_URL=https://immich.example.com/
IMMICH_API_KEY=replace-me

# IANA timezone the camera's clock is set to. Required.
TZ=Europe/Amsterdam

# Optional: defaults shown.
STACK_JPEG_RAF=true
LOG_LEVEL=info
